# Azure AD
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Flask
SECRET_KEY=dev-secret-key-change-in-production
FLASK_ENV=development

# CosmosDB
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DATABASE=certificate-scanner

# Storage
STORAGE_ACCOUNT_URL=https://yourstorageaccount.blob.core.windows.net

# Application Insights
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx;...

# Log Analytics (Data Collection)
LOG_ANALYTICS_WORKSPACE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.OperationalInsights/workspaces/<workspace-name>
LOG_ANALYTICS_DCE_ENDPOINT=https://your-dce.eastus-1.ingest.monitor.azure.com
LOG_ANALYTICS_DCR_IMMUTABLE_ID=dcr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
